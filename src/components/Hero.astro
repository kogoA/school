---
---

<section class="relative overflow-hidden bg-navy text-white pt-24 pb-0">
  <div class="absolute inset-0 bg-[linear-gradient(135deg,#081126_0%,#0f1b3d_58%,#25345f_100%)]"></div>
  <div class="absolute inset-0 opacity-[0.08] [background-image:linear-gradient(#fff_1px,transparent_1px),linear-gradient(90deg,#fff_1px,transparent_1px)] [background-size:48px_48px]"></div>
  <!-- メインコピー -->
  <div class="relative max-w-5xl mx-auto px-4 pt-16 pb-12 text-center">
    <p class="inline-block border border-gold/50 bg-white/8 text-gold text-sm font-bold px-5 py-1.5 rounded-full mb-6 tracking-[0.18em]">
      テスト英語塾バディ
    </p>
    <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6 tracking-wide">
      英語力を確実に伸ばす<br />
      <span class="text-gold">オンライン英語学習</span>
    </h1>
    <p class="text-base md:text-lg text-white/72 mb-9 max-w-2xl mx-auto leading-relaxed">
      経験豊富な講師と二人三脚で、あなたの英語学習を徹底サポート。<br class="hidden md:block" />
      ビジネス英語から受験英語まで幅広く対応します。
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
      <a
        href="#contact"
        class="bg-gold hover:bg-gold-dark text-navy-dark hover:text-white font-bold px-8 py-4 rounded-full text-base transition-colors shadow-[0_18px_48px_rgba(200,164,93,0.32)]"
      >
        無料体験レッスンに申し込む →
      </a>
      <a
        href="#courses"
        class="border border-white/40 hover:border-gold hover:bg-white/10 hover:text-gold text-white font-bold px-8 py-4 rounded-full text-base transition-colors"
      >
        コースを見る
      </a>
    </div>
  </div>

  <!-- 実績帯 -->
  <div class="relative border-t border-white/10 bg-white/5 backdrop-blur">
    <div class="max-w-5xl mx-auto px-4 py-0">
      <div class="grid grid-cols-3 divide-x divide-white/10">
        <div class="text-center py-8 px-4">
          <p class="text-xs text-white/55 mb-1 tracking-widest uppercase">累計受講生</p>
          <p class="text-4xl md:text-5xl font-bold text-white leading-none">
            1,000<span class="text-gold text-2xl">+</span>
          </p>
          <p class="text-sm text-white/55 mt-1">名</p>
        </div>
        <div class="text-center py-8 px-4">
          <p class="text-xs text-white/55 mb-1 tracking-widest uppercase">累計レッスン</p>
          <p class="text-4xl md:text-5xl font-bold text-white leading-none">
            1.5<span class="text-gold text-2xl">万</span>
          </p>
          <p class="text-sm text-white/55 mt-1">回以上</p>
        </div>
        <div class="text-center py-8 px-4">
          <p class="text-xs text-white/55 mb-1 tracking-widest uppercase">サービス実績</p>
          <p class="text-4xl md:text-5xl font-bold text-white leading-none">
            7<span class="text-gold text-2xl">年</span>
          </p>
          <p class="text-sm text-white/55 mt-1">以上</p>
        </div>
      </div>
    </div>
  </div>
</section>
