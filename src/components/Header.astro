---
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-navy/95 text-white shadow-[0_12px_40px_rgba(8,17,38,0.22)] backdrop-blur">
  <div class="max-w-6xl mx-auto px-4 h-18 flex items-center justify-between">
    <a href="/" class="text-xl font-bold tracking-wide text-white">
      S.Global
    </a>
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-white/75">
      <a href="#features" class="hover:text-gold transition-colors">S.Globalについて</a>
      <a href="#teachers" class="hover:text-gold transition-colors">選ばれる理由</a>
      <a href="#courses" class="hover:text-gold transition-colors">サポート内容</a>
      <a href="#voice" class="hover:text-gold transition-colors">卒業生の声</a>
      <a href="#faq" class="hover:text-gold transition-colors">よくある質問</a>
      <a
        href="#contact"
        class="border border-gold/70 bg-gold text-navy-dark px-5 py-2 rounded-full font-bold shadow-[0_8px_24px_rgba(200,164,93,0.26)] transition-colors hover:bg-gold-dark hover:text-white"
      >
        無料カウンセリングに申し込む→
      </a>
    </nav>
    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="メニュー"
    >
      <span class="block w-6 h-0.5 bg-white"></span>
      <span class="block w-6 h-0.5 bg-white"></span>
      <span class="block w-6 h-0.5 bg-white"></span>
    </button>
  </div>

  <!-- モバイルメニュー -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 bg-navy px-4 py-4">
    <nav class="flex flex-col gap-4 text-sm font-medium text-white/80">
      <a href="#features" class="hover:text-gold">特徴</a>
      <a href="#teachers" class="hover:text-gold">講師紹介</a>
      <a href="#courses" class="hover:text-gold">コース</a>
      <a href="#voice" class="hover:text-gold">受講生の声</a>
      <a href="#faq" class="hover:text-gold">よくある質問</a>
      <a
        href="#contact"
        class="bg-gold text-navy-dark px-5 py-2 rounded-full text-center font-bold"
      >
        無料相談
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'))
</script>
