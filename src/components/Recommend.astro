---
const items = [
  'ビジネスで英語を使う機会が増えてきた方',
  '英会話スクールに通ったが伸び悩んでいる方',
  'TOEIC・英検のスコアを上げたい方',
  '海外留学・移住を検討している方',
  '忙しくて通学が難しい方',
  '自分のペースで学習したい方',
]
---

<section id="features" class="py-18 px-4 bg-ivory">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-10">
      <p class="text-sm font-bold text-gold tracking-widest mb-2">RECOMMEND</p>
      <h2 class="text-2xl md:text-3xl font-bold text-navy inline-block pb-2">
        S.Globalについて
      </h2>
    </div>
    <div class="grid md:grid-cols-2 gap-3">
      {items.map((item) => (
        <div class="flex items-center gap-3 border border-navy/10 bg-white/80 rounded-xl px-5 py-4 shadow-[0_10px_30px_rgba(8,17,38,0.05)] transition-colors hover:border-gold/60">
          <span class="w-6 h-6 rounded-full border border-gold bg-gold/10 text-gold text-xs flex items-center justify-center shrink-0 font-bold">✓</span>
          <span class="text-sm md:text-base font-medium text-ink">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>
