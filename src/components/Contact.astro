---
---

<section id="contact" class="py-20 px-4 bg-ivory">
  <div class="max-w-2xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-bold text-gold tracking-widest mb-2">CONTACT</p>
      <h2 class="text-2xl md:text-3xl font-bold text-navy">無料体験・お問い合わせ</h2>
      <p class="text-ink/65 mt-3">まずは無料カウンセリングからお気軽にどうぞ</p>
    </div>

    <div class="bg-white rounded-2xl border border-navy/10 shadow-[0_24px_70px_rgba(8,17,38,0.12)] p-8">
      <form id="contact-form" action="https://your-worker.your-subdomain.workers.dev/contact" method="POST" novalidate>
        <div class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-ink mb-1">
              お名前 <span class="text-gold">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="テスト 太郎"
              class="w-full border border-navy/15 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-ink mb-1">
              メールアドレス <span class="text-gold">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="test@example.com"
              class="w-full border border-navy/15 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-ink mb-1">
              電話番号
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="090-0000-0000"
              class="w-full border border-navy/15 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold"
            />
          </div>

          <div>
            <label for="course" class="block text-sm font-medium text-ink mb-1">
              ご希望のコース <span class="text-gold">*</span>
            </label>
            <select
              id="course"
              name="course"
              required
              class="w-full border border-navy/15 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold bg-white"
            >
              <option value="">選択してください</option>
              <option value="business">ビジネス英語コース</option>
              <option value="toeic">TOEIC対策コース</option>
              <option value="conversation">英会話コース</option>
              <option value="undecided">まだ決めていない（相談したい）</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-ink mb-1">
              ご質問・ご要望
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="現在の英語レベルや目標など、何でもお気軽にご記入ください。"
              class="w-full border border-navy/15 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold resize-none"
            ></textarea>
          </div>

          <!-- Cloudflare Turnstile -->
          <div
            class="cf-turnstile"
            data-sitekey="YOUR_TURNSTILE_SITE_KEY"
            data-theme="light"
          ></div>

          <button
            type="submit"
            class="w-full bg-navy hover:bg-navy-dark text-white font-bold py-4 rounded-full text-lg transition-colors shadow-[0_18px_48px_rgba(8,17,38,0.18)]"
          >
            入力内容を確認する
          </button>

          <p class="text-xs text-ink/45 text-center">
            送信後、2営業日以内にご連絡いたします。
          </p>
        </div>
      </form>

      <div id="form-confirm" class="hidden">
        <div class="mb-8 text-center">
          <p class="text-sm font-bold text-gold tracking-widest mb-2">CONFIRM</p>
          <h3 class="text-xl font-bold text-navy">送信内容の確認</h3>
          <p class="text-sm text-ink/60 mt-2">内容をご確認のうえ、問題なければ送信してください。</p>
        </div>

        <dl class="divide-y divide-navy/10 rounded-xl border border-navy/10 bg-ivory/70">
          <div class="grid gap-1 px-4 py-4 md:grid-cols-[140px_1fr] md:gap-4">
            <dt class="text-sm font-bold text-navy">お名前</dt>
            <dd id="confirm-name" class="text-sm text-ink/70 break-words"></dd>
          </div>
          <div class="grid gap-1 px-4 py-4 md:grid-cols-[140px_1fr] md:gap-4">
            <dt class="text-sm font-bold text-navy">メールアドレス</dt>
            <dd id="confirm-email" class="text-sm text-ink/70 break-words"></dd>
          </div>
          <div class="grid gap-1 px-4 py-4 md:grid-cols-[140px_1fr] md:gap-4">
            <dt class="text-sm font-bold text-navy">電話番号</dt>
            <dd id="confirm-phone" class="text-sm text-ink/70 break-words"></dd>
          </div>
          <div class="grid gap-1 px-4 py-4 md:grid-cols-[140px_1fr] md:gap-4">
            <dt class="text-sm font-bold text-navy">ご希望のコース</dt>
            <dd id="confirm-course" class="text-sm text-ink/70 break-words"></dd>
          </div>
          <div class="grid gap-1 px-4 py-4 md:grid-cols-[140px_1fr] md:gap-4">
            <dt class="text-sm font-bold text-navy">ご質問・ご要望</dt>
            <dd id="confirm-message" class="whitespace-pre-wrap text-sm text-ink/70 break-words"></dd>
          </div>
        </dl>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <button
            id="form-back"
            type="button"
            class="w-full rounded-full border border-navy px-6 py-3 text-sm font-bold text-navy transition-colors hover:bg-navy hover:text-white"
          >
            修正する
          </button>
          <button
            id="form-send"
            type="button"
            class="w-full rounded-full bg-navy px-6 py-3 text-sm font-bold text-white shadow-[0_18px_48px_rgba(8,17,38,0.18)] transition-colors hover:bg-navy-dark"
          >
            この内容で送信する
          </button>
        </div>
      </div>

      <div id="form-success" class="hidden text-center py-8">
        <p class="text-3xl mb-4 text-gold">✓</p>
        <h3 class="text-xl font-bold text-navy mb-2">お申し込みありがとうございます</h3>
        <p class="text-ink/65">2営業日以内にご連絡いたします。</p>
      </div>
    </div>
  </div>
</section>

<!-- Cloudflare Turnstile script -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null
  const confirm = document.getElementById('form-confirm')
  const success = document.getElementById('form-success')
  const backBtn = document.getElementById('form-back') as HTMLButtonElement | null
  const sendBtn = document.getElementById('form-send') as HTMLButtonElement | null

  const setConfirmText = (id: string, value: string) => {
    const element = document.getElementById(id)
    if (element) element.textContent = value || '未入力'
  }

  const getFieldValue = (name: string) => {
    const field = form?.elements.namedItem(name)
    if (
      field instanceof HTMLInputElement ||
      field instanceof HTMLTextAreaElement ||
      field instanceof HTMLSelectElement
    ) {
      return field.value.trim()
    }
    return ''
  }

  const showConfirm = () => {
    const course = form?.elements.namedItem('course')
    const courseText = course instanceof HTMLSelectElement
      ? course.selectedOptions[0]?.textContent?.trim() ?? ''
      : ''

    setConfirmText('confirm-name', getFieldValue('name'))
    setConfirmText('confirm-email', getFieldValue('email'))
    setConfirmText('confirm-phone', getFieldValue('phone'))
    setConfirmText('confirm-course', courseText)
    setConfirmText('confirm-message', getFieldValue('message'))

    form?.classList.add('hidden')
    confirm?.classList.remove('hidden')
  }

  const showForm = () => {
    confirm?.classList.add('hidden')
    form?.classList.remove('hidden')
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!form.checkValidity()) {
      form.reportValidity()
      return
    }
    showConfirm()
  })

  backBtn?.addEventListener('click', showForm)

  sendBtn?.addEventListener('click', async () => {
    if (!form || !sendBtn) return

    sendBtn.disabled = true
    sendBtn.textContent = '送信中...'

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
      })
      if (res.ok) {
        confirm?.classList.add('hidden')
        success?.classList.remove('hidden')
      } else {
        alert('送信に失敗しました。時間をおいて再度お試しください。')
        sendBtn.disabled = false
        sendBtn.textContent = 'この内容で送信する'
      }
    } catch {
      alert('送信に失敗しました。ネットワーク接続を確認してください。')
      sendBtn.disabled = false
      sendBtn.textContent = 'この内容で送信する'
    }
  })
</script>
