---
const stats = [
  { label: '受講生満足度', value: '98', unit: '%' },
  { label: '目標スコア達成率', value: '87', unit: '%' },
  { label: '継続率', value: '92', unit: '%' },
  { label: 'リピート率', value: '76', unit: '%' },
]

const achievements = [
  { name: 'テスト A.K. 様', before: '600点', after: '860点', period: '6ヶ月', type: 'TOEIC' },
  { name: 'テスト M.T. 様', before: '準2級', after: '1級', period: '8ヶ月', type: '英検' },
  { name: 'テスト Y.S. 様', before: '英語が話せない', after: 'ビジネス会議で発言できるように', period: '4ヶ月', type: 'ビジネス英語' },
]
---

<section id="results" class="py-20 px-4 bg-navy text-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-bold text-gold tracking-widest mb-2">RESULTS</p>
      <h2 class="text-2xl md:text-3xl font-bold">成果・実績</h2>
      <p class="text-white/65 mt-3">多くの受講生が目標を達成しています</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
      {stats.map((s) => (
        <div class="text-center rounded-2xl border border-white/10 bg-white/[0.06] py-8 px-4 shadow-[0_18px_45px_rgba(0,0,0,0.12)]">
          <p class="text-5xl font-bold text-gold">{s.value}<span class="text-2xl">{s.unit}</span></p>
          <p class="text-white/65 text-sm mt-2">{s.label}</p>
        </div>
      ))}
    </div>

    <h3 class="text-xl font-bold text-center mb-8">受講生の成果事例</h3>
    <div class="grid md:grid-cols-3 gap-6">
      {achievements.map((a) => (
        <div class="rounded-2xl border border-white/10 bg-white/[0.06] p-6">
          <span class="bg-gold text-navy-dark text-xs font-bold px-3 py-1 rounded-full">{a.type}</span>
          <div class="flex items-center justify-center gap-4 my-6">
            <div class="text-center">
              <p class="text-sm text-white/50">受講前</p>
              <p class="text-2xl font-bold text-white">{a.before}</p>
            </div>
            <span class="text-2xl text-gold">→</span>
            <div class="text-center">
              <p class="text-sm text-white/50">受講後</p>
              <p class="text-2xl font-bold text-gold">{a.after}</p>
            </div>
          </div>
          <p class="text-center text-sm text-white/55">{a.name}（{a.period}で達成）</p>
        </div>
      ))}
    </div>
  </div>
</section>
