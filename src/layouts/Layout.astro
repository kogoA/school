---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'テスト英語塾 | オンライン英語学習',
  description = 'テスト英語塾は、英語力を確実に伸ばすオンライン英語学習サービスです。',
} = Astro.props
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

