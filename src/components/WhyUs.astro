---
const points = [
  { label: '知名度だけに囚われない「3つのアメリカ大学群」の戦略的ナビゲート', desc: 'アメリカには2,000以上の大学が存在し、その構造は多層的です。私たちは、単なる知名度や偏ったランキングだけで学校を選ばせることはしません。 世界を変えるエリートが集う「超難関アイビーリーグ」、1クラス平均7名という圧倒的な手厚さで真のリーダーシップを養う富裕層御用達の「名門私立リベラルアーツカレッジ」、高度な実学を学ぶ「州立大学」。 世界大学ランキングの評価基準（大学院の研究力）の裏側まで知り尽くしたプロフェッショナルが、お子様の地頭や特性に100%合致し、将来最も躍進できる最高の教育環境をプロデュースします。', icon: '01' },
  { label: '年間300万〜700万円の減額を勝ち取る「攻めの奨学金設計」', desc: '「アメリカの大学は費用が高すぎる」と諦める必要はありません。アメリカの私立大学には、留学生向けの手厚い奨学金制度が存在します。 私たちは、家庭の支出ポートフォリオを緻密に分析して支給額を最大化させるテクニック（ニードベース）や、お子様の希少価値や才能を120%伝える出願書類の作成（メリットベース）を熟知しています。 さらに、各大学の「入学審査官との長年の深い信頼関係・人脈」を活かした独自の交渉力を背景に、年間300万〜700万円規模の「返済不要の奨学金」獲得を戦略的に実現します。', icon: '02' },
  { label: '全米平均40%の退学率を生き抜く「初学期アジャスト戦略」', desc: 'アメリカの大学は、入学よりも「卒業」が遥かに困難です。1年生からの平均成績（GPA）が基準を下回れば、容赦なく退学処分となるシビアな世界が待っています。 S.Globalでは、つまずきやすい一学期目を完璧に乗り切るため、文法ミスに厳しくないスペイン語や無双できる数学など「戦略的な科目の選び方（裏技）」を指導。さらに、事前に日本語で予習を完成させる特別なアプローチにより、英語力に不安がある状態からでも、現地でAクラスの成績を収めて無事に卒業するための基盤を構築します。', icon: '03' },
]
---

<section class="py-20 px-4 bg-navy text-white">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-bold text-gold tracking-widest mb-2">WHY US</p>
      <h2 class="text-2xl md:text-3xl font-bold">S.Globalが選ばれる4つの理由</h2>
    </div>

    <div class="flex flex-col md:flex-row gap-10 items-center">
      <!-- ドーナツチャート（CSS製） -->
      <div class="shrink-0 flex flex-col items-center gap-3">
        <div class="relative w-44 h-44">
          <svg viewBox="0 0 36 36" class="w-full h-full -rotate-90">
            <circle cx="18" cy="18" r="15.9155" fill="none" stroke="#ffffff1a" stroke-width="3.5" />
            <circle
              cx="18" cy="18" r="15.9155"
              fill="none"
              stroke="#C8A45D"
              stroke-width="3.5"
              stroke-dasharray="98 100"
              stroke-linecap="round"
            />
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span class="text-4xl font-bold text-gold">98</span>
            <span class="text-sm text-white/60">%</span>
          </div>
        </div>
        <p class="text-sm text-white/65 font-medium">合格率100% ？？</p>
      </div>

      <!-- 特徴リスト -->
      <div class="flex-1 space-y-5">
        {points.map((p) => (
          <div class="flex items-start gap-4 rounded-xl border border-white/10 bg-white/[0.06] px-6 py-5 shadow-[0_18px_45px_rgba(0,0,0,0.12)]">
            <span class="shrink-0 text-sm font-bold tracking-widest text-gold">{p.icon}</span>
            <div>
              <h3 class="font-bold text-base mb-1">{p.label}</h3>
              <p class="text-sm text-white/65 leading-relaxed">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-12">
      <a
        href="#contact"
        class="inline-block bg-gold hover:bg-gold-dark text-navy-dark hover:text-white font-bold px-10 py-4 rounded-full text-base transition-colors shadow-[0_18px_48px_rgba(200,164,93,0.25)]"
      >
        無料カウンセリングを申し込む→
      </a>
    </div>
  </div>
</section>
