---
const services = [
  {
    icon: '01',
    title: '',
    desc: '個別伴走カウンセリング 専任カウンセラーがあなた専用の留学ロードマップと出願戦略を策定',
  },
  {
    icon: '02',
    title: '',
    desc: '柔軟なオンライン面談体制 完全オンライン対応。国内外の時差やライフスタイルに合わせ、夜間を含む最適な時間帯に実施',
  },
  {
    icon: '03',
    title: '',
    desc: 'チャットによる相談窓口 面談日以外の気になる疑問やエッセイの進捗も、チャットツールからいつでも気兼ねなく相談可能',
  },
  {
    icon: '04',
    title: '',
    desc: '定期セミナーの録画視聴 開催された各種セミナーの録画をいつでも自由に視聴可能。見逃した回のキャッチアップや、振り返り学習に活用できます',
  },
]
---

<section class="py-16 px-4 bg-white">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {services.map((s) => (
        <div class="flex flex-col items-center text-center gap-3 p-6 rounded-2xl border border-navy/10 bg-white shadow-[0_14px_45px_rgba(8,17,38,0.06)] transition-all hover:border-gold/60">
          <span class="text-sm font-bold tracking-widest text-gold">{s.icon}</span>
          <h3 class="font-bold text-navy text-sm md:text-base">{s.title}</h3>
          <p class="text-xs text-ink/60 leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
